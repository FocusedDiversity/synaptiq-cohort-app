# ---------------------------------------------------------------
# Databricks connection — fill in and copy to .env (never commit)
# ---------------------------------------------------------------

# Workspace URL, e.g. https://adb-1234567890.12.azuredatabricks.net
DATABRICKS_HOST=https://<workspace>.azuredatabricks.net

# SQL Warehouse HTTP path
# Compute → SQL Warehouses → <your warehouse> → Connection details
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/<warehouse-id>

# Auth option A — Personal Access Token (dev / testing)
DATABRICKS_TOKEN=dapi...

# Auth option B — Service Principal OAuth (production)
# Settings → Identity → Service Principals → <your SP> → Client ID / Secret
DATABRICKS_CLIENT_ID=<service-principal-client-id>
DATABRICKS_CLIENT_SECRET=<service-principal-client-secret>
